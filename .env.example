# ── Supabase ─────────────────────────────────────────────────────────────────
# Public anon key — safe to expose in the browser bundle
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service role key — server-side only, NEVER expose in client code
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Vercel Marketplace Integration ───────────────────────────────────────────
# oac_* client ID — used server-side only for token exchange
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
# Slug from the Vercel marketplace listing, e.g. "sovereign-app"
VERCEL_INTEGRATION_SLUG=

# ── Supabase OAuth (for users connecting their own Supabase) ─────────────────
# Register at app.supabase.com → Account → OAuth Apps
# Redirect URI to register: https://sovereignapp.dev/api/auth/supabase/callback
SUPABASE_OAUTH_CLIENT_ID=
SUPABASE_OAUTH_CLIENT_SECRET=
# Public client ID — safe in the browser bundle (used to build the OAuth URL)
VITE_SUPABASE_OAUTH_CLIENT_ID=

# ── Sovereign's own Supabase project (for sovereign-hosted path) ──────────────
# Personal access token from app.supabase.com → Account → Access Tokens
# Used to run schema SQL against Sovereign's DB via the Management API
SOVEREIGN_SUPABASE_REF=
SOVEREIGN_SUPABASE_MANAGEMENT_TOKEN=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Local dev (optional) ──────────────────────────────────────────────────────
# PORT defaults to 5173 if unset
PORT=5173
